{
  email artemprokopev@internet.ru
}

# ==================== PROD: основной домен ====================
stationeden.ru, www.stationeden.ru {
  tls {
    issuer acme {
      email artemprokopev@internet.ru
    }
  }

  encode zstd gzip

  # Socket.IO/WebSocket
  reverse_proxy /lobby* api:4000 {
    header_up Host {http.request.host}
    header_up X-Real-IP {http.request.remote}
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
  }

  # Динамические страницы лобби
  handle /lobby/* {
    reverse_proxy web:3000
  }

  # REST API под /api
  handle /api* {
    uri strip_prefix /api
    reverse_proxy api:4000 {
      header_up Host {http.request.host}
      header_up X-Real-IP {http.request.remote}
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
    }
  }

  # Прямой доступ к /auth
  handle /auth* {
    reverse_proxy api:4000 {
      header_up Host {http.request.host}
      header_up X-Real-IP {http.request.remote}
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
    }
  }

  # CSRF токен
  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  # WASM
  @wasm path *.wasm
  header @wasm Content-Type "application/wasm"

  # Фронтенд
  handle {
    reverse_proxy web:3000
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# ==================== PROD: отдельный API-хост ====================
api.stationeden.ru {
  tls {
    issuer acme {
      email artemprokopev@internet.ru
    }
  }

  encode zstd gzip

  # Socket.IO
  reverse_proxy /lobby* api:4000 {
    header_up Host {http.request.host}
    header_up X-Real-IP {http.request.remote}
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
  }

  # API
  handle {
    reverse_proxy api:4000 {
      header_up Host {http.request.host}
      header_up X-Real-IP {http.request.remote}
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
    }
  }

  # CSRF
  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  # WASM
  @wasm path *.wasm
  header @wasm Content-Type "application/wasm"

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    
    # ИСПРАВЛЕНИЕ CORP (для favicon и картинок)
    Cross-Origin-Resource-Policy "cross-origin"
    Access-Control-Allow-Origin "https://stationeden.ru"
  }
}

# ==================== LOCAL ====================
localhost {
  encode zstd gzip

  # Socket.IO
  reverse_proxy /lobby* api:4000 {
    header_up Host {http.request.host}
    header_up X-Real-IP {http.request.remote}
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
  }

  # Lobby Frontend
  handle /lobby/* {
    reverse_proxy web:3000
  }

  # API
  handle /api* {
    uri strip_prefix /api
    reverse_proxy api:4000 {
      header_up Host {http.request.host}
      header_up X-Forwarded-Proto {http.request.scheme}
    }
  }

  # Auth
  handle /auth* {
    reverse_proxy api:4000 {
      header_up Host {http.request.host}
      header_up X-Forwarded-Proto {http.request.scheme}
    }
  }

  # CSRF
  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  # WASM
  @wasm path *.wasm
  header @wasm Content-Type "application/wasm"

  # Frontend
  handle {
    reverse_proxy web:3000
  }

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}