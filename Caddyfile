# ==================== PROD: основной домен (фронт + /api под одним origin) ====================
stationeden.ru, www.stationeden.ru {
  encode zstd gzip

  # /api/* → обрезаем префикс и шлём в api:4000
  handle /api* {
    uri strip_prefix /api
    reverse_proxy api:4000
  }

  # /auth/* → проксируем как есть (нужен для OAuth коллбэков)
  handle /auth* {
    reverse_proxy api:4000
  }

  # анти-кэш для CSRF
  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  # остальное → фронт
  handle {
    reverse_proxy web:3000
  }

  # безопасные заголовки (HSTS только на проде)
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# ==================== PROD: отдельный API-хост (обратная совместимость) ====================
api.stationeden.ru {
  encode zstd gzip
  reverse_proxy api:4000

  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# ==================== LOCAL: единый origin на https://localhost ====================
# (без HSTS, чтобы не «залипал»)
http://localhost, https://localhost {
  encode zstd gzip

  handle /api* {
    uri strip_prefix /api
    reverse_proxy api:4000
  }

  handle /auth* {
    reverse_proxy api:4000
  }

  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  handle {
    reverse_proxy web:3000
  }

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}
