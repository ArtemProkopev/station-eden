{
  email artemprokopev@internet.ru
}

# ==================== PROD: основной домен ====================
stationeden.ru, www.stationeden.ru {
  tls {
    issuer acme {
      email artemprokopev@internet.ru
      disable_tlsalpn_challenge
    }
  }

  encode zstd gzip

  # WebSocket proxy - ТОЛЬКО для WebSocket соединений
  handle /lobby {
    # Проверяем, это WebSocket upgrade запрос
    @websocket {
      header Connection *Upgrade*
      header Upgrade *websocket*
    }
    reverse_proxy @websocket api:4000 {
      header_up Host {http.request.host}
      header_up X-Real-IP {http.request.remote}
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
      header_up Connection {http.request.header.Connection}
      header_up Upgrade {http.request.header.Upgrade}
    }
    
    # Все остальные запросы к /lobby идут на фронтенд
    reverse_proxy web:3000
  }

  # Динамические маршруты лобби идут на фронтенд
  handle /lobby/* {
    reverse_proxy web:3000
  }

  handle /api* {
    uri strip_prefix /api
    reverse_proxy api:4000
  }

  handle /auth* {
    reverse_proxy api:4000
  }

  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  # Правильный MIME для WebAssembly
  @wasm path *.wasm
  header @wasm Content-Type "application/wasm"

  handle {
    reverse_proxy web:3000
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# ==================== PROD: отдельный API-хост ====================
api.stationeden.ru {
  tls {
    issuer acme {
      email artemprokopev@internet.ru
      disable_tlsalpn_challenge
    }
  }

  encode zstd gzip

  # WebSocket proxy для API домена
  handle /lobby* {
    reverse_proxy api:4000 {
      header_up Host {http.request.host}
      header_up X-Real-IP {http.request.remote}
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
      header_up Connection {http.request.header.Connection}
      header_up Upgrade {http.request.header.Upgrade}
    }
  }

  # Правильный MIME для WebAssembly
  @wasm path *.wasm
  header @wasm Content-Type "application/wasm"

  handle {
    reverse_proxy api:4000
  }

  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# ==================== LOCAL ====================
localhost {
  encode zstd gzip

  # WebSocket proxy для localhost
  handle /lobby {
    @websocket {
      header Connection *Upgrade*
      header Upgrade *websocket*
    }
    reverse_proxy @websocket api:4000 {
      header_up Host {http.request.host}
      header_up X-Real-IP {http.request.remote}
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
      header_up Connection {http.request.header.Connection}
      header_up Upgrade {http.request.header.Upgrade}
    }
    
    reverse_proxy web:3000
  }

  handle /lobby/* {
    reverse_proxy web:3000
  }

  handle /api* {
    uri strip_prefix /api
    reverse_proxy api:4000
  }

  handle /auth* {
    reverse_proxy api:4000
  }

  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  # Правильный MIME для WebAssembly
  @wasm path *.wasm
  header @wasm Content-Type "application/wasm"

  handle {
    reverse_proxy web:3000
  }

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}
