{
  email artemprokopev@internet.ru
}

# ==================== PROD: основной домен ====================
stationeden.ru, www.stationeden.ru {
  tls {
    issuer acme {
      email artemprokopev@internet.ru
      # Не отключаем TLS-ALPN, чтобы не сломать выпуск сертификата в контейнере
      # disable_tlsalpn_challenge
    }
  }

  encode zstd gzip

  # Socket.IO/WebSocket: весь префикс /lobby уходит на API
  reverse_proxy /lobby* api:4000 {
    header_up Host {http.request.host}
    header_up X-Real-IP {http.request.remote}
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
  }

  # Динамические страницы лобби рендерит фронтенд
  handle /lobby/* {
    reverse_proxy web:3000
  }

  # REST API под /api
  handle /api* {
    uri strip_prefix /api
    reverse_proxy api:4000
  }

  # Прямой доступ к /auth (если используете прямые маршруты без /api)
  handle /auth* {
    reverse_proxy api:4000
  }

  # CSRF токен никогда не кэшируем
  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  # Правильный MIME для WebAssembly
  @wasm path *.wasm
  header @wasm Content-Type "application/wasm"

  # Всё остальное — фронтенд
  handle {
    reverse_proxy web:3000
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# ==================== PROD: отдельный API-хост ====================
api.stationeden.ru {
  tls {
    issuer acme {
      email artemprokopev@internet.ru
      # disable_tlsalpn_challenge
    }
  }

  encode zstd gzip

  # Socket.IO/WebSocket префикс
  reverse_proxy /lobby* api:4000 {
    header_up Host {http.request.host}
    header_up X-Real-IP {http.request.remote}
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
  }

  # Остальной API
  handle {
    reverse_proxy api:4000
  }

  # CSRF: не кэшируем
  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  # Правильный MIME для Wasm
  @wasm path *.wasm
  header @wasm Content-Type "application/wasm"

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# ==================== LOCAL ====================
localhost {
  encode zstd gzip

  # Socket.IO/WebSocket
  reverse_proxy /lobby* api:4000 {
    header_up Host {http.request.host}
    header_up X-Real-IP {http.request.remote}
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
  }

  # Динамические страницы лобби — фронтенд
  handle /lobby/* {
    reverse_proxy web:3000
  }

  # REST API под /api
  handle /api* {
    uri strip_prefix /api
    reverse_proxy api:4000
  }

  # Прямой /auth (если нужен)
  handle /auth* {
    reverse_proxy api:4000
  }

  # CSRF не кэшируем
  @csrf path /auth/csrf
  header @csrf Cache-Control "no-store, no-cache, must-revalidate"
  header @csrf Pragma "no-cache"
  header @csrf Expires "0"

  # Правильный MIME для Wasm
  @wasm path *.wasm
  header @wasm Content-Type "application/wasm"

  # Всё остальное — фронтенд
  handle {
    reverse_proxy web:3000
  }

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}
