# --- App ---
NODE_ENV=development
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000

# --- Auth (JWT) ---
# замените на длинные случайные строки (>=32 символов)
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES=15m
# refresh TTL (мс), по умолчанию 30 дней
JWT_REFRESH_TTL_MS=2592000000

# --- Cookies / CSRF ---
COOKIE_SECURE=false
CSRF_COOKIE_NAME=csrf_token

# --- Telegram (опционально) ---
TELEGRAM_LOGIN_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=@your_bot

# --- Database ---
# DATABASE_URL=postgres://eden:edenpwd@localhost:5432/eden
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=eden
POSTGRES_PASSWORD=edenpwd
POSTGRES_DB=eden

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE=http://localhost:4000
NEXT_PUBLIC_ENABLE_TELEGRAM=false
