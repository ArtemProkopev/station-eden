NODE_ENV=production
API_PORT=4000
API_CORS_ORIGIN=https://stationeden.ru,https://www.stationeden.ru
COOKIE_SECURE=true

# JWT (заполнить в Secrets)
JWT_ACCESS_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_TTL_MS=2592000000
ADMIN_EMAILS=your@email.com

# Database
DATABASE_URL=changeme

# Next.js
NEXT_PUBLIC_API_BASE=https://api.stationeden.ru

# Google OAuth
ENABLE_GOOGLE_LOGIN=true
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=changeme
GOOGLE_REDIRECT_URL=https://api.stationeden.ru/auth/google/callback
WEB_AFTER_LOGIN_URL=https://stationeden.ru/profile

# Telegram (optional)
TELEGRAM_LOGIN_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# Email
RESEND_API_KEY=changeme
EMAIL_FROM="Station Eden <noreply@stationeden.ru>"
