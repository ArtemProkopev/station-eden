# === Общие настройки ===
NODE_ENV=production
API_PORT=4000
API_CORS_ORIGIN=https://stationeden.ru,https://www.stationeden.ru
COOKIE_SECURE=true

# === JWT ===
JWT_ACCESS_SECRET=changeme_access_secret
JWT_REFRESH_SECRET=changeme_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_TTL_MS=2592000000

# === Админы ===
ADMIN_EMAILS=admin@example.com,other@example.com

# === БД ===
DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require

# === Frontend (Next.js) ===
# для продакшена лучше ставить /api (единый origin через Caddy)
NEXT_PUBLIC_API_BASE=/api

# === Google OAuth ===
ENABLE_GOOGLE_LOGIN=true
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:4000/auth/google/callback
WEB_AFTER_LOGIN_URL=http://localhost:3000/profile

# === Telegram ===
TELEGRAM_LOGIN_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# === Email (Resend) ===
RESEND_API_KEY=changeme_resend_key
EMAIL_FROM="Station Eden <noreply@stationeden.ru>"

# === Next.js публичные флаги ===
NEXT_PUBLIC_ENABLE_TELEGRAM=false
NEXT_PUBLIC_ENABLE_GOOGLE=true

# === Cookie домены ===
# Локалка → пустые
# Прод → .stationeden.ru
CSRF_COOKIE_DOMAIN=
AUTH_COOKIE_DOMAIN=

# === Caddy (универсальные хосты) ===
PUBLIC_BASE_HOST=stationeden.ru
PUBLIC_BASE_URL=https://stationeden.ru

# === GHCR / Deploy (используются только в CI/CD) ===
SERVER_HOST=1.2.3.4
SERVER_USER=root
SERVER_PASSWORD=changeme_server_password
GHCR_OWNER=your-ghcr-owner
GHCR_USER=your-ghcr-user
GHCR_PAT=your-ghcr-pat
GHCR_REG=ghcr.io
IMAGE_TAG=latest
