{
	"compilerOptions": {
		"target": "ES2020",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"baseUrl": "."
	},
	"exclude": ["node_modules", "**/dist", "**/build", "**/.next"]
}
