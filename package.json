{
	"name": "station-eden",
	"private": true,
	"packageManager": "pnpm@9.6.0",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"dev:web": "pnpm --filter @station-eden/web dev",
		"dev:web:nocache": "pnpm --filter @station-eden/web dev:nocache",
		"dev:api": "dotenv -e apps/api/.env.local -- pnpm --filter @station-eden/api start:dev",
		"dev": "run-p dev:api dev:web",
		"dev:nocache": "run-p dev:api dev:web:nocache",
		"build": "pnpm -r build",
		"build:wasm": "pnpm --filter @station-eden/web build:wasm",
		"migrate:run": "dotenv -e apps/api/.env.local -- pnpm --filter @station-eden/api run migration:run",
		"migrate:revert": "dotenv -e apps/api/.env.local -- pnpm --filter @station-eden/api run migration:revert",
		"clean": "pnpm -r run clean && rimraf node_modules && pnpm store prune",
		"clean:artifacts": "pnpm -r run clean",
		"doctor": "node -e \"console.log('node',process.version);\" && pnpm -v && git rev-parse --short HEAD"
	},
	"devDependencies": {
		"@types/dotenv": "^8.2.3",
		"cross-env": "^10.0.0",
		"dotenv": "^17.2.2",
		"dotenv-cli": "^7.4.1",
		"npm-run-all": "^4.1.5",
		"rimraf": "^3.0.2",
		"tsx": "^4.20.6",
		"typescript": "^5.5.4"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.906.0",
		"nodemailer": "^7.0.6"
	}
}
