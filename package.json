{
  "name": "station-eden",
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cross-env NODE_ENV=development pnpm --filter @station-eden/web dev",
    "dev:web:nocache": "cross-env NODE_ENV=development pnpm --filter @station-eden/web dev:nocache",
    "dev:api": "cross-env NODE_ENV=development pnpm exec dotenv -e apps/api/.env.local -o -- pnpm --filter @station-eden/api start:dev",
    "dev": "run-p dev:api dev:web",
    "dev:nocache": "run-p dev:api dev:web:nocache",

    "build:wasm": "pnpm -C packages/username-generator run build",
    "build": "pnpm run build:wasm && pnpm -r build",

    "migrate:run": "dotenv -e apps/api/.env.local -- pnpm --filter @station-eden/api run migration:run",
    "migrate:revert": "dotenv -e apps/api/.env.local -- pnpm --filter @station-eden/api run migration:revert",

    "check": "pnpm exec knip && pnpm -r exec tsc --noEmit",
    "security": "pnpm audit",
    "ci": "pnpm run build && pnpm run check && pnpm run security",

    "clean": "pnpm -r run clean || true; rimraf node_modules && pnpm store prune",
    "clean:artifacts": "pnpm -r run clean || true",

    "doctor": "node -e \"console.log('node',process.version);\" && pnpm -v && git rev-parse --short HEAD"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^7.4.1",
    "knip": "^5.83.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.2",
    "typescript": "^5.5.4",
    "wasm-pack": "^0.14.0"
  },
  "pnpm": {
    "overrides": {
      "glob": "10.5.0",
      "lodash": "4.17.23",
      "axios": "0.30.2",
      "tar": "7.5.7",
      "tmp": "0.2.4",
      "webpack": "5.104.1",
			"next": "^15.5.10"
    }
  }
}
