# ==========================================================
# =============== WASM / Rust ==============================
# ==========================================================
# Артефакты сборки WASM в web-приложении
apps/web/src/wasm/target/
apps/web/src/wasm/**/target/
apps/web/src/wasm/**/.fingerprint/
apps/web/src/wasm/**/incremental/
apps/web/src/wasm/**/build/
apps/web/src/wasm/**/*.d
apps/web/src/wasm/**/*.rlib
apps/web/src/wasm/**/*.rmeta

# Cargo.lock внутри локального wasm-крейта не обязателен
apps/web/src/wasm/Cargo.lock

# Глобальные Rust артефакты (на случай новых крейтов)
**/target/
**/.fingerprint/
**/incremental/
**/deps/
**/*.d
**/*.rlib
**/*.rmeta

# Папка public/wasm — игнорим всё, кроме рантайм-артефактов
apps/web/public/wasm/*
!apps/web/public/wasm/username_generator.js
!apps/web/public/wasm/username_generator_bg.wasm

