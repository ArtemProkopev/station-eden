{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"target": "es2022",
		"lib": ["dom", "es2022"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"noEmit": true,
		"allowJs": true,
		"incremental": true,
		"isolatedModules": true,
		"plugins": [{ "name": "next" }],
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@/src/*": ["src/*"],
			"@station-eden/shared": ["../../packages/shared/src/index.ts"],
			"@profile/config": ["src/app/profile/config.ts"]
		},
		"types": ["node"]
	},
	"include": ["next-env.d.ts", "src", "types/**/*.d.ts", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
