{
	"compilerOptions": {
		"target": "es2022",
		"lib": ["dom", "es2022"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"strict": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@/src/*": ["src/*"]
		},
		"allowJs": true,
		"skipLibCheck": true,
		"incremental": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"plugins": [{ "name": "next" }],
		"types": ["node"],
		"typeRoots": ["./node_modules/@types"]
	},
	"include": ["next-env.d.ts", "src", "types/**/*.d.ts", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
