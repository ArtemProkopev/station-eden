{
  "name": "@station-eden/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:nocache": "cross-env NEXT_CACHE_DISABLED=1 next dev -p 3000",
    "clean": "rimraf .next",
    "build": "next build",
    "start": "next start -p 3000",
