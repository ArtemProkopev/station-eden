    "livekit-client": "^2.16.0",
    "next": "15.5.12",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.66.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "15.5.12",
    "rimraf": "^6.1.2",
    "typescript": "^5.5.4"
  }
