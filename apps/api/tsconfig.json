{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"module": "Node16",
		"moduleResolution": "node16",
		"target": "es2020",
		"rootDir": ".",
		"outDir": "dist",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"types": ["node", "cookie-parser", "jest"],
		"ignoreDeprecations": "5.0"
	},
	"include": ["src/**/*.ts", "test/**/*.ts"]
}
