{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2019",

		"rootDir": "src",
		"outDir": "dist",

		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,

		"types": ["node", "cookie-parser"],
		"typeRoots": ["./node_modules/@types", "../../node_modules/@types"]
	},
	"include": ["src/**/*.ts"]
}
