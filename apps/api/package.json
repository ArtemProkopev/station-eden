{
	"name": "@station-eden/api",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"start:dev": "nest start --watch",
		"clean": "rimraf dist",
		"build": "nest build",
		"typeorm": "ts-node -T ./node_modules/typeorm/cli.js",
		"migration:generate": "cross-env TS_NODE_PROJECT=tsconfig.json ts-node -T ./node_modules/typeorm/cli.js migration:generate -d ./src/db/data-source.ts",
		"migration:create": "cross-env TS_NODE_PROJECT=tsconfig.json ts-node -T ./node_modules/typeorm/cli.js migration:create",
		"migration:run": "cross-env TS_NODE_PROJECT=tsconfig.json ts-node -T ./node_modules/typeorm/cli.js migration:run -d ./src/db/data-source.ts",
		"migration:revert": "cross-env TS_NODE_PROJECT=tsconfig.json ts-node -T ./node_modules/typeorm/cli.js migration:revert -d ./src/db/data-source.ts"
	},
	"dependencies": {
		"@nestjs/common": "^10.0.0",
		"@nestjs/config": "^3.1.1",
		"@nestjs/core": "^10.0.0",
		"@nestjs/jwt": "^10.2.0",
		"@nestjs/passport": "^10.0.2",
		"@nestjs/platform-express": "^10.0.0",
		"@nestjs/platform-socket.io": "^10.0.0",
		"@nestjs/throttler": "^6.1.0",
		"@nestjs/typeorm": "^11.0.0",
		"@nestjs/websockets": "^10.4.20",
		"@station-eden/shared": "workspace:^",
		"bcryptjs": "^2.4.3",
		"cookie": "^1.0.2",
		"cookie-parser": "^1.4.6",
		"dotenv": "^17.2.4",
		"helmet": "^7.1.0",
		"livekit-server-sdk": "^2.14.2",
		"nestjs-zod": "^5.0.1",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"pg": "^8.11.3",
		"reflect-metadata": "^0.1.13",
		"resend": "^4.0.0",
		"rxjs": "^7.8.2",
		"socket.io": "^4.8.1",
		"typeorm": "^0.3.20",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@nestjs/cli": "^10.4.9",
		"@nestjs/schematics": "^10.0.2",
		"@types/bcryptjs": "^3.0.0",
		"@types/cookie-parser": "^1.4.9",
		"@types/express": "^5.0.3",
		"@types/node": "^20.19.14",
		"@types/passport-jwt": "^4.0.1",
		"cross-env": "^10.0.0",
		"rimraf": "^6.1.2",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"typescript": "^5.5.4"
	}
}
