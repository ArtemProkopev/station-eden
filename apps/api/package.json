{
	"name": "@station-eden/api",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"start:dev": "nest start --watch",
		"clean": "rimraf dist",
		"build": "nest build",
		"typeorm": "ts-node -T ./node_modules/typeorm/cli.js",
		"migration:generate": "cross-env TS_NODE_PROJECT=tsconfig.json ts-node -T ./node_modules/typeorm/cli.js migration:generate -d ./src/db/data-source.ts",
		"migration:create": "cross-env TS_NODE_PROJECT=tsconfig.json ts-node -T ./node_modules/typeorm/cli.js migration:create",
		"migration:run": "cross-env TS_NODE_PROJECT=tsconfig.json ts-node -T ./node_modules/typeorm/cli.js migration:run -d ./src/db/data-source.ts",
		"migration:revert": "cross-env TS_NODE_PROJECT=tsconfig.json ts-node -T ./node_modules/typeorm/cli.js migration:revert -d ./src/db/data-source.ts"
	},
	"dependencies": {
		"@nestjs/common": "^10.0.0",
		"@nestjs/config": "^3.1.1",
		"@nestjs/core": "^10.0.0",
		"@nestjs/jwt": "^10.2.0",
		"@nestjs/passport": "^10.0.2",
		"@nestjs/platform-express": "^10.0.0",
		"@nestjs/platform-socket.io": "^10.0.0",
		"@nestjs/throttler": "^6.1.0",
		"@nestjs/typeorm": "^11.0.0",
		"@nestjs/websockets": "^10.4.20",
		"bcryptjs": "^2.4.3",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.0",
		"cookie": "^1.0.2",
		"cookie-parser": "^1.4.6",
		"csurf": "^1.11.0",
		"dotenv": "^17.2.2",
		"google-auth-library": "^10.3.0",
		"helmet": "^7.1.0",
		"jsonwebtoken": "^9.0.2",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"pg": "^8.11.3",
		"reflect-metadata": "^0.1.13",
		"resend": "^4.0.0",
		"rimraf": "^3.0.2",
		"rxjs": "^7.8.2",
		"socket.io": "^4.8.1",
		"typeorm": "^0.3.20",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@nestjs/cli": "^10.4.5",
		"@nestjs/schematics": "^10.0.2",
		"@nestjs/testing": "^10.0.0",
		"@types/bcryptjs": "^3.0.0",
		"@types/cookie": "^1.0.0",
		"@types/cookie-parser": "^1.4.9",
		"@types/dotenv": "^8.2.3",
		"@types/express": "^5.0.3",
		"@types/node": "^20.19.14",
		"@types/passport-jwt": "^4.0.1",
		"cross-env": "^10.0.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.5.4"
	}
}
