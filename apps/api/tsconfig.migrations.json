{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist/migrations",
		"rootDir": "./migrations",
		"module": "commonjs",
		"target": "ES2020",
		"sourceMap": false,
		"declaration": false,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true
	},
	"include": ["migrations/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
